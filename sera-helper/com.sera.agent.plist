<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sera.agent</string>

  <key>ProgramArguments</key>
  <array>
    <string>__SERA_BIN__</string>
    <string>serve</string>
    <string>--port</string>
    <string>8765</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>StandardOutPath</key>
  <string>__SERA_HOME__/logs/agent.log</string>

  <key>StandardErrorPath</key>
  <string>__SERA_HOME__/logs/agent.err</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>SERA_HOME</key>
    <string>__SERA_HOME__</string>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>
</dict>
</plist>
